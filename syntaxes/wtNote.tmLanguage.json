{
    "scopeName": "source.wtNote",
    "patterns": [
        { "include": "#mdLink" },
        { "include": "#urlLink" },
        { "include": "#expression" },
        { "include": "#comments" }
    ],
    "repository": {
        "mdLink": {
            "match": "\\[.*?\\]\\(.*?\\)",
            "name": "keyword"
        },
        "urlLink": {
            "match": "(https?|ftp):\\/\\/[^\\s\/$.?#].[^\\s]*",
            "name": "keyword"
        },
        "expression": {
            "patterns": [{ "include": "#separatorLine" }]
        },
        "separatorLine": {
            "match": ".*-- ALSO, DON'T DELETE THIS LINE!",
            "name": "keyword.separatorLine"
        },
        "comments": {
            "name": "comment.line.number-sign.wt",
            "begin": "\\[",
            "patterns": [{
                "include": "#comments"
            }],
            "end": "\\]"
        }
    }
}