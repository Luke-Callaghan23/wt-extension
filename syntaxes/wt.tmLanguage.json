{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "wt",
    "scopeName": "source.wt",
    "patterns": [
        { "include": "#mdLink" },
        { "include": "#urlLink" },
        { "include": "#comments" }
    ],
    "repository": {
        "mdLink": {
            "match": "\\[.*?\\]\\(.*?\\)",
            "name": "keyword"
        },
        "urlLink": {
            "match": "(https?|ftp):\\/\\/[^\\s\/$.?#].[^\\s]*",
            "name": "keyword"
        },
        "comments": {
            "name": "comment.line.number-sign.wt",
            "begin": "\\[",
            "patterns": [{
                "include": "#comments"
            }],
            "end": "\\]"
        }
    }
}